# Désactive le categorical sur les colonnes utilisées comme index/columns de pivot,
# pour éviter "cannot insert into a categorical index" partout dans le notebook.
for col in ['type_porteur', 'label_banque', 'annee', 'periode_tri', 'periode_label', 'mois_annee']:
    if col in df.columns and df[col].dtype.name == 'category':
        df[col] = df[col].astype(str)
